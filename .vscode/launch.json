{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Serverless",
            "runtimeExecutable": "nodemon",
            "runtimeArgs": [
                "--exec",
                "serverless",
                "offline",
                "--config",
                "nodemon.json"
            ],
            "port": 3000, // Change this if your app runs on a different port
            "outFiles": [
                "${workspaceFolder}/**/*.js"
            ],
            "env": {
                "NODE_ENV": "development" // Set any environment variables if needed
            },
            "console": "integratedTerminal"
        }
    ]
}
